// ─── Backend URL ─────────────────────────────────────────────────────────────
const BACKEND_URL = "http://127.0.0.1:8888";

// ─── Element refs ─────────────────────────────────────────────────────────────
const loginBtn        = document.getElementById("loginBtn");
const logoutBtn       = document.getElementById("logoutBtn");
const playBtn         = document.getElementById("playBtn");
const pauseBtn        = document.getElementById("pauseBtn");
const prevBtn         = document.getElementById("prevBtn");
const nextBtn         = document.getElementById("nextBtn");
const searchBtn       = document.getElementById("searchBtn");
const searchInput     = document.getElementById("searchInput");
const browseBtn       = document.getElementById("browseBtn");
const trackName       = document.getElementById("trackName");
const artistName      = document.getElementById("artistName");
const currentTime     = document.getElementById("currentTime");
const loginSection    = document.getElementById("loginSection");
const playerSection   = document.getElementById("playerSection");
const searchResults   = document.getElementById("searchResults");
const recommendedResults = document.getElementById("recommendedResults");
const queueSidebar    = document.getElementById("queueSidebar");
const queueList       = document.getElementById("queueList");
const clearQueueBtn   = document.getElementById("clearQueueBtn");
const importPlaylistBtn = document.getElementById("importPlaylistBtn");
const playlistInput   = document.getElementById("playlistInput");
const livePill        = document.getElementById("livePill");
const waveform        = document.getElementById("waveform");

// ─── State ────────────────────────────────────────────────────────────────────
let accessToken      = localStorage.getItem("spotify_token");
let currentPlayer    = null;
let deviceId         = null;   // BUG FIX #2 — store device_id from SDK "ready" event
let queue            = [];
let currentQueueIndex = -1;
let isPlaying        = false;

// ─── Initialize stored session ────────────────────────────────────────────────
window.addEventListener("DOMContentLoaded", async () => {
  if (accessToken) {
    // Token exists in localStorage, restore the session
    showPlayerSection();
    initSpotifyPlayer();
  }
});

// ─── BUG FIX #3 — Register onSpotifyWebPlaybackSDKReady BEFORE any conditional
// logic so it is always in place when the SDK script fires, even for returning
// users whose token was restored from localStorage on load.
window.onSpotifyWebPlaybackSDKReady = () => {
  if (!accessToken) return;   // token not ready yet — initSpotifyPlayer() will be
                               // called again once login completes
  _createPlayer();
};

function initSpotifyPlayer() {
  // If the SDK has already fired and set Spotify on window, create the player
  // immediately. Otherwise onSpotifyWebPlaybackSDKReady (registered above) will
  // handle creation once the script loads.
  if (window.Spotify) {
    _createPlayer();
  }
  // else: SDK not yet ready — the global callback above will fire and call _createPlayer()
}

function _createPlayer() {
  if (currentPlayer) return; // already initialised

  currentPlayer = new Spotify.Player({
    name: "Sakura Player",
    getOAuthToken: (cb) => { cb(accessToken); },
    volume: 0.6,
  });

  // BUG FIX #2 — capture device_id when player is ready
  currentPlayer.addListener("ready", ({ device_id }) => {
    deviceId = device_id;
    console.log("Player ready, device_id:", device_id);
  });

  currentPlayer.addListener("not_ready", ({ device_id }) => {
    console.warn("Device went offline:", device_id);
    deviceId = null;
  });

  // BUG FIX #1 — correct event name is "player_state_changed", not "player_update"
  currentPlayer.addListener("player_state_changed", (state) => {
    if (!state) return;

    const track = state.track_window?.current_track;
    if (track) {
      trackName.textContent  = track.name;
      artistName.textContent = track.artists.map((a) => a.name).join(", ");
    }

    // Update play/pause button state to match actual playback state
    const paused = state.paused;
    setPlayingState(!paused);

    // Sync time display
    const secs  = Math.floor(state.position / 1000);
    const mins  = Math.floor(secs / 60);
    const rem   = String(secs % 60).padStart(2, "0");
    currentTime.textContent = `${mins}:${rem}`;
  });

  currentPlayer.addListener("initialization_error", ({ message }) => console.error("Init error:", message));
  currentPlayer.addListener("authentication_error", ({ message }) => console.error("Auth error:", message));
  currentPlayer.addListener("account_error",        ({ message }) => console.error("Account error:", message));

  currentPlayer.connect();
}

// ─── Play / pause UI helper ───────────────────────────────────────────────────
function setPlayingState(playing) {
  isPlaying = playing;
  playBtn.style.display  = playing ? "none" : "flex";
  pauseBtn.style.display = playing ? "flex" : "none";
  if (waveform) {
    waveform.classList.toggle("paused", !playing);
  }
}

// ─── Login ────────────────────────────────────────────────────────────────────
loginBtn.addEventListener("click", () => {
  const authWindow = window.open(
    `${BACKEND_URL}/login`,
    "Spotify Login",
    "width=500,height=600"
  );

  window.addEventListener("message", function handler(event) {
    if (event.data.type === "auth_success") {
      accessToken = event.data.token;
      localStorage.setItem("spotify_token", accessToken);
      authWindow?.close();
      showPlayerSection();
      initSpotifyPlayer();
      window.removeEventListener("message", handler);
    }
  });
});

// ─── Logout ───────────────────────────────────────────────────────────────────
logoutBtn.addEventListener("click", async () => {
  try {
    await fetch(`${BACKEND_URL}/logout`, { method: "POST" });
  } catch (err) {
    console.error("Logout error:", err);
  }

  if (currentPlayer) {
    currentPlayer.disconnect();
    currentPlayer = null;
  }

  accessToken      = null;
  deviceId         = null;
  queue            = [];
  currentQueueIndex = -1;

  localStorage.removeItem("spotify_token");
  loginSection.style.display  = "block";
  playerSection.style.display = "none";
  queueSidebar.style.display  = "none";
  searchResults.style.display = "none";
  recommendedResults.style.display = "none";
  if (livePill) livePill.style.display = "none";

  trackName.textContent  = "No track playing";
  artistName.textContent = "—";
  setPlayingState(false);
  updateQueueDisplay();
});

// ─── Show player UI ───────────────────────────────────────────────────────────
function showPlayerSection() {
  loginSection.style.display  = "none";
  playerSection.style.display = "block";
  queueSidebar.style.display  = "block";
  if (livePill) livePill.style.display = "inline-flex";
}

// ─── Play control ─────────────────────────────────────────────────────────────
playBtn.addEventListener("click", () => {
  if (currentPlayer) currentPlayer.resume();
});

pauseBtn.addEventListener("click", () => {
  if (currentPlayer) currentPlayer.pause();
});

// ─── Previous / Next ──────────────────────────────────────────────────────────
prevBtn.addEventListener("click", () => {
  if (queue.length > 0 && currentQueueIndex > 0) {
    currentQueueIndex--;
    playQueueTrack(currentQueueIndex);
  } else if (currentPlayer) {
    currentPlayer.previousTrack();
  }
});

nextBtn.addEventListener("click", () => {
  if (queue.length > 0 && currentQueueIndex < queue.length - 1) {
    currentQueueIndex++;
    playQueueTrack(currentQueueIndex);
  } else if (currentPlayer) {
    currentPlayer.nextTrack();
  }
});

// ─── Search ───────────────────────────────────────────────────────────────────
searchBtn.addEventListener("click", () => {
  const query = searchInput.value.trim();
  console.log("Search button clicked. Query:", query, "Token exists:", !!accessToken);
  if (accessToken && query) {
    searchSpotify(query);
  } else {
    console.warn("Search failed - missing token or query");
  }
});

searchInput.addEventListener("keydown", (e) => {
  if (e.key === "Enter" && accessToken && searchInput.value.trim()) {
    searchSpotify(searchInput.value.trim());
  }
});

// Browse recommendations
browseBtn.addEventListener("click", () => {
  console.log("Browse button clicked");
  if (accessToken) {
    loadRecommendations();
  } else {
    console.warn("Browse failed - missing token");
  }
});

async function searchSpotify(query) {
  try {
    console.log("Searching for:", query);
    const res = await fetch(
      `${BACKEND_URL}/search?q=${encodeURIComponent(query)}`,
      { headers: { Authorization: `Bearer ${accessToken}` } }
    );
    
    if (!res.ok) {
      console.error("Search API error:", res.status, res.statusText);
      displaySearchResults([]);
      return;
    }
    
    const data = await res.json();
    console.log("Search results:", data.tracks?.items?.length ?? 0, "tracks found");
    displaySearchResults(data.tracks?.items ?? []);
  } catch (err) {
    console.error("Search error:", err);
    displaySearchResults([]);
  }
}

async function loadRecommendations() {
  try {
    console.log("Loading recommendations");
    const res = await fetch(
      `${BACKEND_URL}/recommendations`,
      { headers: { Authorization: `Bearer ${accessToken}` } }
    );
    
    if (!res.ok) {
      console.error("Recommendations API error:", res.status, res.statusText);
      displayRecommendations([]);
      return;
    }
    
    const data = await res.json();
    const tracks = data.items || [];
    
    console.log("Recommendations loaded:", tracks.length, "tracks found");
    displayRecommendations(tracks);
  } catch (err) {
    console.error("Recommendations error:", err);
    displayRecommendations([]);
  }
}

function displaySearchResults(tracks) {
  searchResults.innerHTML = "";

  if (tracks.length === 0) {
    searchResults.innerHTML = `<p style="padding:12px 16px; font-size:12px; color:var(--muted);">No tracks found</p>`;
    searchResults.style.display = "block";
    return;
  }

  tracks.forEach((track) => {
    const item = document.createElement("div");
    item.className = "result-item";
    item.innerHTML = `
      <div class="result-name">${track.name}</div>
      <div class="result-artist">${track.artists.map((a) => a.name).join(", ")}</div>
    `;
    item.addEventListener("click", () => {
      addToQueue(track);
      searchResults.style.display = "none";
      searchInput.value = "";
    });
    searchResults.appendChild(item);
  });

  searchResults.style.display = "block";
}

function displayRecommendations(tracks) {
  recommendedResults.innerHTML = "";

  if (tracks.length === 0) {
    recommendedResults.innerHTML = `<p style="padding:12px 16px; font-size:12px; color:var(--muted);">No recommendations available</p>`;
    recommendedResults.style.display = "block";
    return;
  }

  tracks.forEach((track) => {
    const item = document.createElement("div");
    item.className = "result-item";
    item.innerHTML = `
      <div class="result-name">${track.name}</div>
      <div class="result-artist">${track.artists.map((a) => a.name).join(", ")}</div>
    `;
    item.addEventListener("click", () => {
      addToQueue(track);
      recommendedResults.style.display = "none";
    });
    recommendedResults.appendChild(item);
  });

  recommendedResults.style.display = "block";
}

// ─── Queue management ─────────────────────────────────────────────────────────
function addToQueue(track) {
  queue.push({
    uri:    track.uri,
    name:   track.name,
    artist: track.artists.map((a) => a.name).join(", "),
    id:     track.id,
  });

  updateQueueDisplay();

  if (queue.length === 1) {
    currentQueueIndex = 0;
    playQueueTrack(0);
  }
}

function updateQueueDisplay() {
  if (queue.length === 0) {
    queueList.innerHTML = '<p class="queue-empty">🌷 Nothing queued yet</p>';
    return;
  }

  queueList.innerHTML = "";

  queue.forEach((track, index) => {
    const item = document.createElement("div");
    item.className = "queue-item" + (index === currentQueueIndex ? " playing" : "");

    item.innerHTML = `
      <div class="qi-info">
        <div class="qi-name">${track.name}</div>
        <div class="qi-artist">${track.artist}</div>
      </div>
      <span class="qi-remove" data-index="${index}">×</span>
    `;

    item.querySelector(".qi-remove").addEventListener("click", (e) => {
      e.stopPropagation();
      removeFromQueue(Number(e.target.dataset.index));
    });

    item.addEventListener("click", (e) => {
      if (!e.target.classList.contains("qi-remove")) {
        currentQueueIndex = index;
        playQueueTrack(index);
      }
    });

    queueList.appendChild(item);
  });
}

function removeFromQueue(index) {
  queue.splice(index, 1);
  if (currentQueueIndex >= queue.length) currentQueueIndex = queue.length - 1;
  updateQueueDisplay();
}

// ─── BUG FIX #2 — pass device_id so Spotify knows where to play ──────────────
async function playQueueTrack(index) {
  if (index < 0 || index >= queue.length || !currentPlayer) return;

  const track = queue[index];
  currentQueueIndex = index;

  currentPlayer._options.getOAuthToken(async (token) => {
    try {
      // device_id is required — without it Spotify silently ignores the request
      const url = deviceId
        ? `https://api.spotify.com/v1/me/player/play?device_id=${deviceId}`
        : "https://api.spotify.com/v1/me/player/play";

      await fetch(url, {
        method:  "PUT",
        headers: {
          Authorization:  `Bearer ${token}`,
          "Content-Type": "application/json",
        },
        body: JSON.stringify({ uris: [track.uri] }),
      });

      updateQueueDisplay();
    } catch (err) {
      console.error("Play error:", err);
    }
  });
}

// ─── Clear queue ──────────────────────────────────────────────────────────────
clearQueueBtn.addEventListener("click", () => {
  queue            = [];
  currentQueueIndex = -1;
  updateQueueDisplay();
});

// ─── Import playlist ──────────────────────────────────────────────────────────
importPlaylistBtn.addEventListener("click", () => {
  const input = playlistInput.value.trim();
  if (!input) { alert("Please paste a Spotify playlist link"); return; }
  importPlaylist(input);
});

async function importPlaylist(playlistUrl) {
  try {
    let playlistId = null;
    const match = playlistUrl.match(/playlist\/([a-zA-Z0-9]+)/);
    if (match) {
      playlistId = match[1];
    } else if (/^[a-zA-Z0-9]+$/.test(playlistUrl)) {
      playlistId = playlistUrl;
    } else {
      alert("Invalid Spotify playlist link.");
      return;
    }

    const res = await fetch(
      `https://api.spotify.com/v1/playlists/${playlistId}/tracks`,
      { headers: { Authorization: `Bearer ${accessToken}` } }
    );

    if (!res.ok) throw new Error("Playlist not found or inaccessible");

    const data = await res.json();
    if (!data.items?.length) { alert("Playlist is empty"); return; }

    let added = 0;
    const wasEmpty = queue.length === 0;

    data.items.forEach(({ track: t }) => {
      if (t?.uri) {
        queue.push({
          uri:    t.uri,
          name:   t.name,
          artist: t.artists.map((a) => a.name).join(", "),
          id:     t.id,
        });
        added++;
      }
    });

    if (added > 0) {
      if (wasEmpty) {
        currentQueueIndex = 0;
        playQueueTrack(0);
      }
      updateQueueDisplay();
      alert(`Added ${added} tracks to queue!`);
    }

    playlistInput.value = "";
  } catch (err) {
    console.error("Import error:", err);
    alert("Error importing playlist: " + err.message);
  }
}

// ─── Restore session on load ──────────────────────────────────────────────────
window.addEventListener("load", () => {
  const saved = localStorage.getItem("spotify_token");
  if (saved) {
    accessToken = saved;
    showPlayerSection();
    // initSpotifyPlayer will be called once SDK fires window.onSpotifyWebPlaybackSDKReady
    // (which is already registered above). If SDK already fired, call directly.
    if (window.Spotify) initSpotifyPlayer();
  }
});
